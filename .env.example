# Groq API — free tier, used for autocomplete + sentence improvement
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# ElevenLabs TTS (optional — falls back to browser speech synthesis)
ELEVENLABS_API_KEY=
ELEVENLABS_JR_VOICE_ID=          # Default: EXAVITQu4vr4xnSDxMaL (Sarah)

# Privacy & consent (#118)
PRIVACY_GRACE_PERIOD_DAYS=30     # days between withdraw and hard-delete
PRIVACY_ADMIN_TOKEN=             # required to hit /api/privacy/admin; empty = 404

# COPPA email-plus Verifiable Parental Consent
# HMAC secret for signed step-1/step-2 tokens. Required in production.
VPC_TOKEN_SECRET=
# Delay in ms between step-1 confirmation and step-2 email send. Default 600000 (10 min).
VPC_STEP2_DELAY_MS=600000
# Shared-secret bearer token for the admin audit log route. Rotate often.
VPC_ADMIN_TOKEN=
# Directory for the JSONL audit log + email outbox stub. Defaults to ./data/consent
VPC_AUDIT_DIR=

# AgentMail — transactional email for VPC + privacy notifications.
# Without AGENTMAIL_API_KEY the app falls back to LogOnlySender (console + JSONL outbox).
# Get a key from https://console.agentmail.to — scope it to the sending inbox.
AGENTMAIL_API_KEY=
# Inbox to send from. Must exist in your AgentMail org and match the key's scope.
AGENTMAIL_FROM_INBOX=privacy@8gentjr.com

# Clerk accounts v1 (13+ path only; under-13 stays device-bound via VPC)
# Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
